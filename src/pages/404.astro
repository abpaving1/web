---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found | AB Paving & Landscaping Glasgow" description="" hasAnnouncement={false}>
<main id="main-content" class="error-page">
  <div class="error-inner">
    <div class="error-num">404</div>
    <h1 class="error-title">Page Not Found</h1>
    <p class="error-msg">Sorry, we couldn't find the page you were looking for. It may have moved or been removed. Head back to our homepage or get in touch — we're always happy to help.</p>
    <div class="error-links">
      <a href="/" class="btn-primary">Back to Homepage</a>
      <a href="tel:07492263394" class="btn-white" style="background:var(--navy);color:white">📞 Call 07492 263394</a>
    </div>
  </div>
</main>

<section class="cta-sec">
  <h2>Need a <span>Free Quote?</span></h2>
  <p>Call us on <strong style="color:var(--yellow)">07492 263394</strong> or fill in our quick quote form.</p>
  <div class="cta-btns">
    <a href="/#contact" class="btn-primary">Get a Free Quote</a>
    <a href="tel:07492263394" class="btn-white">📞 Call 07492 263394</a>
  </div>
</section>
</Layout>
